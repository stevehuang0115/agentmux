# =============================================================================
# Crewly SMB Environment Configuration
#
# Copy this file to .env.smb and fill in your values.
# Required: at least one AI model API key.
# =============================================================================

# --- AI Model Keys (at least one required) ---
# GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Local AI (Ollama) ---
# OLLAMA_HOST=http://host.docker.internal:11434

# --- Slack Integration (optional) ---
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_APP_TOKEN=xapp-your-slack-app-token

# --- Cloud Auth (optional, for relay/multi-device) ---
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:10021/api/cloud/auth/callback
# CREWLY_JWT_SECRET=your-jwt-secret-change-in-production
# MONGO_DB_HOST=mongodb://localhost:27017
# MONGO_DB_USER=
# MONGO_DB_PASS=

# --- Deployment ---
CREWLY_VERSION=latest
CREWLY_PORT=8787
AUTH_PORT=10021
AUTH_VERSION=latest
