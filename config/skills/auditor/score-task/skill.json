{
  "id": "auditor-score-task",
  "name": "Score Task",
  "description": "Score a completed task's quality (0-100) for tracking per-agent quality metrics.",
  "assignableTo": ["auditor"],
  "type": "script",
  "script": "execute.sh",
  "timeout": 15000,
  "triggers": ["score task", "quality score", "rate task"],
  "parameters": {
    "taskId": { "type": "string", "required": true, "description": "ID of the completed task to score" },
    "qualityScore": { "type": "number", "required": true, "description": "Quality score 0-100" },
    "sessionName": { "type": "string", "required": false, "description": "Session name of the scorer" }
  }
}
