# Crewly Environment Variables
# Copy this file to .env and fill in your values.
# Env vars override local config files and constants defaults.

# ============================================================
# Server
# ============================================================

# HTTP port for the Crewly backend (default: 8787 via WEB_PORT, or 3000 via PORT)
# PORT=3000
# WEB_PORT=8787

# Bind host (default: localhost)
# HOST=localhost

# Node environment: development | production | test
NODE_ENV=development

# Optional: Log level (debug, info, warn, error)
LOG_LEVEL=info

# Optional: Headless mode — API-only, no frontend serving
# CREWLY_HEADLESS=false

# ============================================================
# Secrets & Auth (REQUIRED in production)
# ============================================================

# JWT signing secret for local auth system
# MUST be set to a strong random value in production
# CREWLY_JWT_SECRET=your-strong-random-secret-here

# Encryption key for stored OAuth refresh tokens
# CREWLY_TOKEN_ENCRYPTION_KEY=your-encryption-key-here
# (Alternative: CREWLY_SECRET)

# ============================================================
# Supabase (Cloud Auth — Backend)
# ============================================================

# Supabase project URL (defaults to dev project)
# CREWLY_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key (defaults to dev project anon key)
# CREWLY_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================
# Supabase (Cloud Auth — Frontend / Vite)
# ============================================================
# These are read by the Vite frontend at build time.
# If unset, the frontend falls back to the same dev-project defaults.

# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================
# CrewlyAI Cloud
# ============================================================

# Cloud API base URL (default: https://cloud.crewly.dev)
# CREWLY_CLOUD_URL=https://cloud.crewly.dev

# Crewly home directory (default: ~/.crewly)
# CREWLY_HOME=~/.crewly

# Backend API URL (used by orchestrator bash skills)
# CREWLY_API_URL=http://localhost:8787

# ============================================================
# AI Provider Keys
# ============================================================

# Gemini API Key (for embeddings and Gemini CLI agents)
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# Slack Integration
# ============================================================
# Get these from https://api.slack.com/apps
#
# Required Bot Token Scopes:
#   - app_mentions:read   (receive @mentions)
#   - channels:read       (access channel info)
#   - chat:write          (send messages)
#   - im:history          (read DM history)
#   - im:read             (access DM info)
#   - im:write            (start DMs)
#
# Optional Bot Token Scopes:
#   - reactions:write     (add typing/complete indicators with emoji reactions)

SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Optional: Default channel for notifications
# SLACK_DEFAULT_CHANNEL=C123456789

# Optional: Comma-separated list of allowed user IDs
# SLACK_ALLOWED_USERS=U111,U222,U333

# ============================================================
# Google OAuth (for Gmail integration)
# ============================================================

# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8787/api/oauth/google/callback

# ============================================================
# WhatsApp Integration (optional)
# ============================================================

# WHATSAPP_ENABLED=false
# WHATSAPP_PHONE_NUMBER=+1234567890
# WHATSAPP_AUTH_PATH=~/.crewly/whatsapp-auth
# WHATSAPP_ALLOWED_CONTACTS=+111,+222,+333

# ============================================================
# MCP Server
# ============================================================

# MCP server port (default: 3001)
# CREWLY_MCP_PORT=3001

# MCP enabled (default: true)
# MCP_ENABLED=true

# ============================================================
# Advanced / Performance
# ============================================================

# Maximum concurrent agents (default: 50)
# MAX_CONCURRENT_AGENTS=50

# Agent default timeout in ms (default: 300000 = 5 min)
# AGENT_DEFAULT_TIMEOUT=300000

# Session secret for express-session (REQUIRED in production)
# SESSION_SECRET=your-session-secret-here
